---
interface Props {
    alt: string;
    src: string;
}

const { alt, src } = Astro.props;
---

<style>
    .wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1em;
        margin: 1em;
    }

    .content {
        flex-grow: 1;
        width: 100%;
    }

    .image {
        width: 30%;
        flex-grow: 0;
        flex-shrink: 0;
    }

    img {
        max-width: 100%;
        height: auto;
        max-height: 25vw;
    }

    @media (max-width: 820px) {
        .wrapper {
            flex-direction: column;
        }

        .image {
            width: 45%;
        }
    }

    @media (max-width: 480px) {
        .image {
            width: 90%;
        }
    }
</style>
<div class="wrapper">
    <div class="image">
        <a href={src}><img src={src} alt={alt} /></a>
    </div>
    <div class="content">
        <slot />
    </div>
</div>
